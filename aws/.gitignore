# Local .terraform directories
.terraform/

# Terraform state (never commit)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which may contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Lock file (optional: some teams commit .terraform.lock.hcl for provider versions)
# Uncomment the next line if you do not want to commit the lock file:
# .terraform.lock.hcl