# Copy to .env and adjust values.
# Compose reads this file automatically when named .env next to docker-compose.yml.

COMPOSE_PROJECT_NAME=three-tier

# Docker network name (bridge)
APP_NETWORK_NAME=three-tier-app-net

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=appdb
MYSQL_USER=app
MYSQL_PASSWORD=change-me-app

# API (host machine port -> container)
API_HOST_PORT=3000
API_INTERNAL_PORT=3000
DB_HOST=db
DB_PORT=3306

# Frontend (browser -> nginx)
FRONTEND_HOST_PORT=8080

# Host:port nginx proxies to (Compose service name + internal API port)
NGINX_API_UPSTREAM=api:3000
